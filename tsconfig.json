{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ES2022",
    "lib": ["ES2023"],
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "jest"],
    "baseUrl": ".",
    "paths": {
      "@prisma/client": ["../danusin-backend/node_modules/@prisma/client"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["e2e/**/*", "node_modules"]
}
